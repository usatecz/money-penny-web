GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Comma-separated origins always allowed (localhost variants for Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Dev troubleshooting: when true, also allow any http(s) origin via regex.
# Required for Authorization Bearer + allow_credentials=True (cannot use allow_origins=["*"]).
# Set to false in production and rely on CORS_ORIGINS only.
CORS_PERMISSIVE_DEV=true

HOST=0.0.0.0
PORT=8000
